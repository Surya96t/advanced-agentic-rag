# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# Required fields are marked with (REQUIRED).

# ─── Clerk Authentication ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key   # (REQUIRED)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key                         # (REQUIRED)

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Backend ──────────────────────────────────────────────────────────────────
FASTAPI_BASE_URL=http://localhost:8000   # (REQUIRED) — FastAPI backend URL

# ─── Revalidation Secret ──────────────────────────────────────────────────────
# Used to authenticate on-demand ISR revalidation requests.
# Generate with: openssl rand -hex 32
# Must match the value configured in your deployment environment.
REVALIDATE_SECRET=your-high-entropy-secret-here   # (REQUIRED)
