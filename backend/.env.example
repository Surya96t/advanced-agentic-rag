# Environment Variables Template
# Copy this file to .env and fill in your values
# Required fields are marked with (REQUIRED) — the app will not start without them.

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=False                       # Always False in production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                   # json (production) | console (development)

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. In production, list your exact frontend URL(s).
CORS_ORIGINS='["http://localhost:3000"]'
CORS_ALLOW_CREDENTIALS=true

# ─── Database: Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co           # (REQUIRED)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key     # (REQUIRED) — service role, never expose to browser
SUPABASE_DB_PASSWORD=your-supabase-db-password          # (REQUIRED) — direct PostgreSQL password
SUPABASE_POOLER_REGION=aws-0-us-east-1                  # Supabase connection pooler region

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_TIMEOUT=30

# ─── Authentication: Clerk ────────────────────────────────────────────────────
CLERK_SECRET_KEY=your-clerk-secret-key                  # (REQUIRED)
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key        # (REQUIRED)
CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev    # (REQUIRED)
AUTH_ENABLED=true
CLERK_JWKS_CACHE_TTL=3600

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                   # Leave blank if no auth
REDIS_SSL=false                   # Set true for managed Redis in production
REDIS_CONNECTION_POOL_SIZE=10

# ─── Response Cache (Redis) ───────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400           # 24 hours

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_REQUESTS=50    # Default: 50 requests per hour
RATE_LIMIT_DEFAULT_WINDOW=3600    # Window in seconds (1 hour)
RATE_LIMIT_BURST_MULTIPLIER=1.5

# Per-endpoint limits (requests per hour)
RATE_LIMIT_CHAT=50                # LLM calls — rate limited to control cost
RATE_LIMIT_INGEST=10              # Expensive: triggers OpenAI embeddings
RATE_LIMIT_DOCUMENTS=200          # Read-only, cheap

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key    # (REQUIRED)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ─── Cohere (optional — production re-ranking) ────────────────────────────────
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=rerank-english-v3.0

# ─── LangSmith (optional — AI observability) ─────────────────────────────────
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=advanced-agentic-rag

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=supabase          # supabase | azure
STORAGE_BUCKET=documents          # Supabase Storage bucket name

# ─── LangGraph Checkpointing ─────────────────────────────────────────────────
ENABLE_CHECKPOINTING=true         # Enables persistent conversation history via PostgreSQL

# ─── RAG — Chunking ───────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── RAG — Vector Search ─────────────────────────────────────────────────────
VECTOR_SEARCH_TOP_K=20
VECTOR_SEARCH_MIN_SIMILARITY=0.7

# ─── RAG — Text Search (PostgreSQL FTS) ──────────────────────────────────────
TEXT_SEARCH_TOP_K=20
TEXT_SEARCH_MIN_RANK=0.01

# ─── RAG — Hybrid Search (RRF Fusion) ────────────────────────────────────────
HYBRID_SEARCH_ALPHA=0.7           # 0.0=text only, 1.0=vector only, 0.7=favour semantic
HYBRID_RRF_K=60

# ─── RAG — Re-ranking ────────────────────────────────────────────────────────
RERANK_ENABLED=true
RERANK_MODEL=ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=5

# ─── RAG — Validation ────────────────────────────────────────────────────────
VALIDATION_PASS_THRESHOLD=0.5
VALIDATION_RETRY_THRESHOLD=0.4
VALIDATION_MAX_RETRIES=2

# ─── Conversational Memory ────────────────────────────────────────────────────
MAX_CONVERSATION_TOKENS=8000
RECENT_MESSAGE_COUNT=10
RERANK_TOP_K=10

# Rate Limits
MAX_FILE_SIZE_MB=5
MAX_DOCUMENTS_PER_USER=50
MAX_STORAGE_MB_PER_USER=100
MAX_TOKENS_PER_MONTH=1000000
