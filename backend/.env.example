# Environment Variables Template
# Copy this file to .env and fill in your values

# Application
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# CORS Settings (JSON array format)
CORS_ORIGINS='["http://localhost:3000", "http://localhost:3001"]'
CORS_ALLOW_CREDENTIALS=true

# Database (Supabase)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key

# Authentication (Clerk)
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Cohere (optional - for production re-ranking)
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=rerank-english-v3.0

# LangSmith (observability - optional but recommended)
# Get your API key from https://smith.langchain.com/
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=integration-forge-rag

# RAG Configuration - Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG Configuration - Vector Search
VECTOR_SEARCH_TOP_K=20
VECTOR_SEARCH_MIN_SIMILARITY=0.7

# RAG Configuration - Text Search (PostgreSQL FTS)
TEXT_SEARCH_TOP_K=20
TEXT_SEARCH_MIN_RANK=0.01

# RAG Configuration - Hybrid Search (RRF Fusion)
HYBRID_SEARCH_ALPHA=0.5
HYBRID_RRF_K=60

# RAG Configuration - Re-ranking
RERANK_ENABLED=true
RERANK_MODEL=ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=10

# Rate Limits
MAX_FILE_SIZE_MB=5
MAX_DOCUMENTS_PER_USER=50
MAX_STORAGE_MB_PER_USER=100
MAX_TOKENS_PER_MONTH=1000000
